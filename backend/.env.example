PORT=5000

# MongoDB Atlas (recommended). Replace USER, PASSWORD, and cluster host with yours.
# URL-encode special characters in the password (e.g. @ → %40).
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/grabit-hot?retryWrites=true&w=majority

JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Admin dashboard login (used by npm run seed:admin). Defaults: admin@gmail.com / ali12345@@
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=ali12345@@

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
FROM_EMAIL=noreply@grabit-hot.com
FROM_NAME=Grab It Hot

# One or more allowed browser origins (comma-separated). Localhost is always allowed for dev.
# Example: https://myapp.com,https://www.myapp.com
CLIENT_URL=http://localhost:3000
